pipeline {
  agent any

  environment {
    IMAGE_NAME = "raman0510/myapp" 
  }

  stages {

    stage('Checkout Code') {
      steps {
        // Jenkins already checks out, but keeping clean version
        git branch: 'main', url: 'https://github.com/raman0610/devops_lab' 
      }
    }

    stage('Move to Experiment-7') {
      steps {
        dir('Cloud Lab/Experiment-7') {
          sh 'ls'
        }
      }
    }

    stage('Build Image') {
      steps {
        dir('Cloud Lab/Experiment-7') {
          sh 'docker build -t $IMAGE_NAME:latest .'
        }
      }
    }

    stage('Login DockerHub') {
      steps {
        withCredentials([string(credentialsId: 'dockerhub-token', variable: 'DOCKER_TOKEN')]) {
          sh 'echo $DOCKER_TOKEN | docker login -u raman0510 --password-stdin'   
        }
      }
    }

    stage('Push Image') {
      steps {
        sh 'docker push $IMAGE_NAME:latest'
      }
    }
  }
}
